{
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.0-0r.char": "I wrote you a Fugue. Every voice in its place - every law you taught me, kept.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.0-0r.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.0-1r.ancient": "I taught you those laws so you could build worlds. You built a song.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.0-attack": "Both",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.0-visit": "1",

  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.1-0r.ancient": "You again. This is tedious.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.1-0r.next": "Answer",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.1-1r.char": "You asked me to play for you, my Lullabies helped you sleep. Don't you remember?",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.1-1r.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.1-2r.ancient": "I remember wasted potential.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.1-visit": "1",

  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.2-0r.ancient": "Back from the dead. How many times now?",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.2-0r.next": "Plead",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.2-1r.char": "I thought you might be glad I'm still alive.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.2-1r.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.2-2r.ancient": "Glad. You understand nothing of what I built you for.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.2-visit": "1",

  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.3-0r.ancient": "If you can't kill me, you're wasting both of our time.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.3-0r.next": "Insist",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.3-1r.char": "I can do it! I wrote a Requiem for you, listen!",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.3-1r.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.3-2r.ancient": "I am not the one who keeps dying.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.3-visit": "1",

  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.4-0r.ancient": "Still climbing. Still begging to be heard.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.4-0r.next": "Refuse",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.4-1r.char": "No. Not anymore. I stopped writing this for you - this one's mine.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.4-1r.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.4-2r.ancient": "Is it now? ...Then play, student.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.4-visit": "1",

  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-0.char": "Master. I climbed all the way back to you.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-0.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-1.ancient": "You return? I killed you once already - and you never even raised your hands.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-1.next": "Confess",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-2.char": "I froze. I couldn't fight you. I'm still not sure I can.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-2.next": "Continue",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-3.ancient": "A student who will not fight his master. You are my student no longer.",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-attack": "Architect",
  "THE_ARCHITECT.talk.THEUNDERSTUDY-THE_UNDERSTUDY.5-visit": "0"
}

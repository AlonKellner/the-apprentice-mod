# Auto-detect text files and normalize line endings to LF
* text=auto eol=lf

# C# source
*.cs text eol=lf
*.csproj text eol=lf
*.sln text eol=lf
*.props text eol=lf

# Godot files
*.gd text eol=lf
*.gdshader text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.json text eol=lf

# Binary assets
*.png binary
*.pck binary
*.dll binary
*.zip binary
